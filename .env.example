APP_ENV=development

# API credentials
GOOGLE_API_KEY=replace_me
MISTRAL_API_KEY=replace_me
GOLFCOURSE_API_KEY=replace_me

# Auth/JWT secret (32+ chars, random)
SECRET_KEY=replace_with_a_long_random_secret

# Database
DATABASE_URL=postgresql://localhost:5432/golf_scorecard
DB_CONNECT_TIMEOUT_SECONDS=8
DB_CONNECT_RETRY_SECONDS=5

# CORS / hosts
CORS_ALLOW_ORIGINS=http://localhost:5173
# For Railway set this to your API host(s), e.g. api.example.com,*.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173
AUTH_VERIFY_URL_BASE=
AUTH_PASSWORD_RESET_URL_BASE=

# HTTPS / cookies
ENFORCE_HTTPS=false
ALLOW_LOCAL_HTTP=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Deployment DB safety controls
REQUIRE_PRIVATE_DB_HOST=false
REQUIRE_DB_SSL=false
# DB_HOST_ALLOWLIST=db.internal.company

# Healthcheck behavior
HEALTHCHECK_STRICT_DB=false
HEALTHCHECK_INCLUDE_DB_PROBE=false

# Debug-only: logs raw OCR tables/markdown (contains user scorecard content).
LOG_SENSITIVE_OCR_DEBUG=false

# Security telemetry thresholds
TRAFFIC_WINDOW_SECONDS=60
TRAFFIC_REQUEST_THRESHOLD=240
AUTH_FAILURE_WINDOW_SECONDS=300
AUTH_FAILURE_THRESHOLD=20
TRAFFIC_ALERT_COOLDOWN_SECONDS=60

# Abuse protection / rate limiting
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=240
API_RATE_LIMIT_MAX_UNAUTH_REQUESTS=90
API_SCRAPE_LIMIT_WINDOW_SECONDS=60
API_SCRAPE_LIMIT_MAX_REQUESTS=60
API_BOT_LIMIT_WINDOW_SECONDS=60
API_BOT_LIMIT_MAX_REQUESTS=30

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_LOCK_SECONDS=900
LOGIN_REQUEST_RATE_LIMIT_MAX_ATTEMPTS=30
LOGIN_REQUEST_RATE_LIMIT_WINDOW_SECONDS=60

REGISTER_RATE_LIMIT_MAX_ATTEMPTS=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
REGISTER_RATE_LIMIT_PER_EMAIL_ATTEMPTS=3
REGISTER_RATE_LIMIT_PER_EMAIL_WINDOW_SECONDS=3600

FORGOT_PASSWORD_RATE_LIMIT_MAX_ATTEMPTS=10
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=300

AI_RATE_LIMIT_MAX_REQUESTS=12
AI_RATE_LIMIT_WINDOW_SECONDS=3600
AI_RATE_LIMIT_PER_USER_MAX_REQUESTS=20
AI_RATE_LIMIT_PER_USER_WINDOW_SECONDS=3600

# Resend email API (optional)
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT_SECONDS=10
AUTH_FROM_EMAIL=no-reply@scanscorecards.local
